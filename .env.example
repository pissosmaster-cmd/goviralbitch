# Only YOUTUBE_DATA_API_KEY is required. All LLM work runs through Claude Code.
#
# Viral Command — Environment Variables
# Copy this file to .env and fill in your API keys.
# See SETUP.md for where to get each key.

# ──────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────

# YouTube Data API v3 — analytics collection, thumbnail fetch, search
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ──────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────

# Anthropic — used by recon skeleton ripper for LLM calls (optional, Claude Code handles LLM interactively)
# ANTHROPIC_API_KEY=

# Google API — additional Google service access
# GOOGLE_API_KEY=

# ──────────────────────────────────────
# INSTAGRAM (optional — run scripts/setup-ig-token.py to populate)
# ──────────────────────────────────────

# Instagram Graph API — per-Reel insights, follower growth
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
